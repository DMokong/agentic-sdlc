# Copy this to .env.local and fill in your TfNSW API key
# Get a key at: https://opendata.transport.nsw.gov.au/
VITE_TFNSW_API_KEY=your_api_key_here

# If you encounter CORS issues with TfNSW API during development,
# you can add a Vite proxy (does NOT change the production architecture):
# In vite.config.ts, add:
# server: {
#   proxy: {
#     '/v1/tp': {
#       target: 'https://api.transport.nsw.gov.au',
#       changeOrigin: true,
#     }
#   }
# }
